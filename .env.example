# ===========================================
# Iridia Notes - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ----- Backend Configuration -----
# Secret key for JWT signing (generate a secure random string for production)
SECRET_KEY=

# JWT settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----- Database Configuration -----
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Database URL (used by backend)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<host>:5432/<db_name>

# ----- Frontend Configuration -----
# API URL for Vite build (compile time)
# - Local dev (npm run dev): http://localhost:8000 (direct to backend)
# - Docker/Railway (nginx proxy): "" (empty, uses nginx /api proxy)
VITE_API_URL=http://localhost:8000

# Backend URL for nginx proxy (runtime)
# - docker-compose: backend:8000
# - Railway: <backend-service>.railway.internal:<port>
BACKEND_URL=backend:8000

# DNS resolver for nginx (auto-detected by default)
# - auto: Detect from /etc/resolv.conf (recommended)
# - 127.0.0.11: Docker's internal DNS
# - 1.1.1.1 or 8.8.8.8: Public DNS (fallback)
DNS_RESOLVER=auto
